# ─────────────────────────────────────────────────────────────
# Required — copy this file to .env.local and fill in values
# ALL of these must also be set in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Supabase (get from Supabase Dashboard → Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (used by the /api/admin/generate proxy route)
OPENAI_API_KEY=sk-...

# Firecrawl (used by the /api/admin/firecrawl/crawl proxy route)
FIRECRAWL_API_KEY=fc-...
